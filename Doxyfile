# The RTF_OUTPUT tag is used to specify where the RTF pages will be put.
RTF_OUTPUT             = rtf

# If the COMPACT_RTF tag is set to YES doxygen will generate more compact
# RTF output.
COMPACT_RTF            = NO

# If the RTF_HYPERLINKS tag is set to YES, the RTF that is generated will have
# hyperlinks.
RTF_HYPERLINKS         = NO

# Load stylesheet definitions from file.
RTF_STYLESHEET_FILE    = 

# Set optional variables used in the generation of an rtf document.
RTF_EXTENSIONS_FILE    = 

#---------------------------------------------------------------------------
# Configuration options related to the man page output
#---------------------------------------------------------------------------

# If the GENERATE_MAN tag is set to YES doxygen will generate man pages
GENERATE_MAN           = NO

# The MAN_OUTPUT tag is used to specify where the man pages will be put.
MAN_OUTPUT             = man

# The MAN_EXTENSION tag determines what extension is used for the generated
# man pages (default is the subroutine's section number).
MAN_EXTENSION          = .3

# If the MAN_LINKS tag is set to YES and Doxygen generates man output,
# then it will generate links pointing to the man pages from the HTML output.
MAN_LINKS              = NO

#---------------------------------------------------------------------------
# Configuration options related to the XML output
#---------------------------------------------------------------------------

# If the GENERATE_XML tag is set to YES doxygen will generate an XML file
# that captures the structure of the code including all documentation.
GENERATE_XML           = NO

# The XML_OUTPUT tag is used to specify where the XML pages will be put.
XML_OUTPUT             = xml

# If the XML_PROGRAMLISTING tag is set to YES doxygen will dump the program
# listings (code snippets) into the XML output.
XML_PROGRAMLISTING     = YES

# If the XML_NS_MEMB_FILE_SCOPE tag is set to YES, doxygen will include
# namespace member files (*.xml) even if they only contain namespace members
# and no detailed namespace description.
XML_NS_MEMB_FILE_SCOPE = NO

#---------------------------------------------------------------------------
# Configuration options related to the DOCBOOK output
#---------------------------------------------------------------------------

# If the GENERATE_DOCBOOK tag is set to YES doxygen will generate Docbook files
# that can be used to generate PDF documents by using tools like dblatex.
GENERATE_DOCBOOK       = NO

# The DOCBOOK_OUTPUT tag is used to specify where the Docbook pages will be put.
DOCBOOK_OUTPUT         = docbook

# If the DOCBOOK_PROGRAMLISTING tag is set to YES doxygen will include the
# program listings (code snippets) into the DOCBOOK output.
DOCBOOK_PROGRAMLISTING = NO

#---------------------------------------------------------------------------
# Configuration options for the AutoGen Definitions output
#---------------------------------------------------------------------------

# If the GENERATE_AUTOGEN_DEF tag is set to YES doxygen will generate an
# AutoGen Definitions (see autogen.sourceforge.net) file that captures the
# structure of the code including all documentation.
GENERATE_AUTOGEN_DEF   = NO

#---------------------------------------------------------------------------
# Configuration options related to the Perl module output
#---------------------------------------------------------------------------

# If the GENERATE_PERLMOD tag is set to YES doxygen will generate a Perl module
# file that captures the structure of the code including all documentation.
GENERATE_PERLMOD       = NO

# If the PERLMOD_LATEX tag is set to YES doxygen will generate the necessary
# Makefile rules, Fortran stubs and additional libraries to build the Perl
# module.
PERLMOD_LATEX          = NO

# Set the qualifiers that should be excluded from the (anonymous) namespaces
# list.
PERLMOD_SKIP_NAMESPACES = 

#---------------------------------------------------------------------------
# Configuration options related to the preprocessor
#---------------------------------------------------------------------------

# If the ENABLE_PREPROCESSING tag is set to YES doxygen will evaluate all
# C-preprocessor directives found in the sources and include files.
ENABLE_PREPROCESSING   = YES

# If the MACRO_EXPANSION tag is set to YES doxygen will expand all macro names
# in the source code within comments and documentation.
MACRO_EXPANSION        = NO

# If the EXPAND_ONLY_PREDEF tag is set to YES, the macro expansion is limited
# to the macros specified with the PREDEFINED and EXPAND_AS_DEFINED tags.
EXPAND_ONLY_PREDEF     = NO

# If the SEARCH_INCLUDES tag is set to YES the includes files in the
# INCLUDE_PATH will be searched if a #include is found.
SEARCH_INCLUDES        = YES

# The INCLUDE_PATH tag can be used to specify one or more paths that contain
# include files.
INCLUDE_PATH           = 

# You can use the INCLUDE_FILE_PATTERNS tag to specify one or more wildcard
# patterns (like *.h and *.hpp) to filter out the header-files in the
# directories.
INCLUDE_FILE_PATTERNS  = 

# The PREDEFINED tag can be used to specify one or more macro names that are
# defined before the preprocessor is started (similar to the -D option used by
# gcc).
PREDEFINED             = 

# If the MACRO_EXPANSION and SEARCH_INCLUDES tags are set to YES then the
# preprocessor will expand all macro names in the source code within comments
# and documentation.
EXPAND_AS_DEFINED      = 

# If the SKIP_FUNCTION_MACROS tag is set to YES then doxygen's preprocessor
# will remove all reentrant and non-reentrant function-like macros from the
# input.
SKIP_FUNCTION_MACROS   = YES

#---------------------------------------------------------------------------
